# App Config
APP_ENV=dev
APP_PORT=8080
LOG_LEVEL=INFO

# Security
# Dùng để xác thực webhook từ TradingView
TRADINGVIEW_SHARED_SECRET=your_actual_shared_secret_here

# Database
# Local standard:
# - Chạy app trên host bằng uvicorn
# - Chạy PostgreSQL bằng `docker compose up -d db`
# Nếu chạy app container qua docker compose, service `app` sẽ override DATABASE_URL sang host `db`.
# Format: postgresql+psycopg://user:password@host:5432/dbname
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/signal_bot

# Telegram API
TELEGRAM_BOT_TOKEN=123456789:ABCDefghIJKLmnopQRSTuvwxYZ
TELEGRAM_MAIN_CHAT_ID=-100123456789
TELEGRAM_WARN_CHAT_ID=-100987654321
TELEGRAM_ADMIN_CHAT_ID=123456789

# Dashboard auth (optional — nếu không set, dashboard public)
DASHBOARD_TOKEN=your-secret-token-here

# Integration tests — PostgreSQL (optional — nếu không set, integration tests bị skip)
# INTEGRATION_DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/test_db

# Rate Limiting
# Max requests per minute to webhook endpoint per IP address
WEBHOOK_RATE_LIMIT=50
